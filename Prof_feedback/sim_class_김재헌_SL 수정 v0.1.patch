+    def diagnose_scattering_kernel(self, wavelengths, theta_array, backend="internal",
+                                   use_polydispersity=False):
+        """Return fast, non-Monte-Carlo diagnostics for the scattering kernel.
+
+        This helper is intended for debugging Manoharan/PNAS reproduction:
+        it reports Mie-only and form*structure cross sections for both the
+        monodisperse Percus--Yevick and Ginoza-Yasutomi structure factors.
+        """
+        theta_array = np.asarray(theta_array, dtype=float)
+        rows = []
+
+        if use_polydispersity:
+            radius_samples, size_pdf = self._get_schulz_distribution()
+        else:
+            radius_samples, size_pdf = None, None
+
+        for wavelength in np.atleast_1d(wavelengths):
+            wavelength = float(wavelength)
+            n_eff_complex = self._get_n_eff_ps_matrix(wavelength)
+            n_p_complex = self.get_n_p_real_sellmeier(wavelength) + 1j * self.k_p
+            q = self.get_q(np.real(n_eff_complex), theta_array, wavelength)
+
+            diff_eff, csca_eff, _, _ = self._get_mie_absorbing(
+                wavelength, n_p_complex, n_eff_complex, theta_array, backend=backend
+            )
+            diff_mat, csca_mat, _, _ = self._get_mie_absorbing(
+                wavelength, n_p_complex, complex(self.n_matrix, 0.0), theta_array, backend=backend
+            )
+
+            out = {
+                "wavelength": wavelength,
+                "n_eff_real": float(np.real(n_eff_complex)),
+                "n_eff_imag": float(np.imag(n_eff_complex)),
+                "csca_mie_effective": float(csca_eff),
+                "csca_mie_matrix": float(csca_mat),
+            }
+
+            for name, S in [
+                ("py", self._get_structure_factor_percus_yevick(q)),
+                ("ginoza", self._get_structure_factor_ginoza(q)),
+            ]:
+                diff_sample = diff_eff * S
+                csca_sample = 2.0 * np.pi * np.trapezoid(
+                    diff_sample * np.sin(theta_array), theta_array
+                )
+                phase = diff_sample / csca_sample
+                cdf, theta_pdf = self._cdf_phase(phase, theta_array)
+                l_scat = self._get_l_scat(csca_sample, radius_samples, size_pdf)
+                l_star = self._get_l_star(l_scat, theta_pdf, theta_array)
+                out[f"csca_sample_{name}"] = float(csca_sample)
+                out[f"weighted_S_{name}"] = float(csca_sample / csca_eff)
+                out[f"l_scat_{name}"] = float(l_scat)
+                out[f"l_star_{name}"] = float(l_star)
+                out[f"Smax_{name}"] = float(np.max(S))
+
+            rows.append(out)
+
+        return rows
+
+    # Backward-friendly alias for the same diagnostic helper.
+    def kernel_diagnostics(self, wavelengths, theta_array, backend="internal",
+                           use_polydispersity=False):
