+    def _get_structure_factor_percus_yevick(self, q):
+        """Monodisperse Percus--Yevick hard-sphere structure factor.
+
+        This is the same analytical glass structure factor used in the
+        Manoharan structural-color package for `structure_type='glass'`.
+        Input q has units 1/length; internally qd = q * d, where d=2r.
+        """
+        q = np.asarray(q, dtype=float)
+        qd = q * (2.0 * self.r_i)
+        qd_safe = np.where(np.abs(qd) < 1e-8, 1e-8, qd)
+        phi = float(self.phi)
+
+        if not (0.0 <= phi < 1.0):
+            raise ValueError("self.phi must be in [0, 1) for Percus-Yevick S(q).")
+
+        lambda1 = (1.0 + 2.0 * phi)**2 / (1.0 - phi)**4
+        lambda2 = -(1.0 + phi / 2.0)**2 / (1.0 - phi)**4
+
+        c = -24.0 * phi * (
+            lambda1 * (np.sin(qd_safe) - qd_safe * np.cos(qd_safe)) / qd_safe**3
+            - 6.0 * phi * lambda2
+            * (
+                qd_safe**2 * np.cos(qd_safe)
+                - 2.0 * qd_safe * np.sin(qd_safe)
+                - 2.0 * np.cos(qd_safe)
+                + 2.0
+            )
+            / qd_safe**4
+            - (phi * lambda1 / 2.0)
+            * (
+                qd_safe**4 * np.cos(qd_safe)
+                - 4.0 * qd_safe**3 * np.sin(qd_safe)
+                - 12.0 * qd_safe**2 * np.cos(qd_safe)
+                + 24.0 * qd_safe * np.sin(qd_safe)
+                + 24.0 * np.cos(qd_safe)
+                - 24.0
+            )
+            / qd_safe**6
+        )
+
+        S = 1.0 / (1.0 - c)
+        return np.clip(np.real_if_close(S), 0.0, None)
+
